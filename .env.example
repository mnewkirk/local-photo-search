# local-photo-search — environment configuration
# Copy this file to .env and edit the values.

# Path to your photo library on the host machine.
# This gets mounted read-only into the container at /photos.
#
# Examples:
#   Mac development:  PHOTO_DIR=/Users/matt/Pictures/2026
#   UGREEN NAS:       PHOTO_DIR=/volume1/photos
PHOTO_DIR=/path/to/your/photos

# Port for the web UI (default: 8000)
WEB_PORT=8000

# LLaVA model for scene descriptions (default: llava)
# Options: llava (7B, faster), llava:13b (better quality, needs ~10 GB RAM)
# DESCRIBE_MODEL=llava

# Vision model for hallucination verification (default: minicpm-v)
# Must differ from DESCRIBE_MODEL — cross-model verification catches
# hallucinations that same-model verification misses.
# VERIFY_MODEL=minicpm-v
